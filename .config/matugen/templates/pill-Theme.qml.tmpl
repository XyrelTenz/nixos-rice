    readonly property color flameCore: "{{base16.base06.default.hex}}"
    readonly property color flameGlow: "{{base16.base09.default.hex}}"

    /**
     * Flame canvas ramp: literal hex strings (color type won't work), fed
     * directly to Canvas addColorStop/strokeStyle. A color property serializes
     * to #aarrggbb and corrupts the gradient render.
     */
    readonly property string flameInk:   "{{base16.base08.default.hex}}"
    readonly property string flameEmber: "{{base16.base0f.default.hex}}"
    readonly property string flameBurn:  "{{base16.base0f.default.hex}}"
    readonly property string flameTip:   "{{base16.base09.default.hex}}"
    readonly property color todayWarm: "{{base16.base09.default.hex}}"
    readonly property color ghost:     "{{base16.base03.default.hex}}"
    readonly property color frameBg:      Qt.rgba({{base16.base05.default.red}}/255, {{base16.base05.default.green}}/255, {{base16.base05.default.blue}}/255, 0.055)
    readonly property color frameBorder:  Qt.rgba({{base16.base05.default.red}}/255, {{base16.base05.default.green}}/255, {{base16.base05.default.blue}}/255, 0.10)
    readonly property color creamMenu:     Qt.rgba({{base16.base05.default.red}}/255, {{base16.base05.default.green}}/255, {{base16.base05.default.blue}}/255, 0.82)
    readonly property real shadowOpacity: 0.5
    readonly property string font: "Inter"
    readonly property string fontJp: "Zen Kaku Gothic New"

    /**
     * MPRIS trackArtists arrives as a JS array from some players and as a
     * plain string from others (Spotify); calling join on the string throws
     * and kills the whole binding. Handles both, falls back to trackArtist.
     */
    function joinArtists(artists, single) {
        if (artists && typeof artists.join === "function" && artists.length > 0)
            return artists.join(", ");
        if (artists && String(artists).length > 0)
            return String(artists);
        return single ? String(single) : "";
    }
}
