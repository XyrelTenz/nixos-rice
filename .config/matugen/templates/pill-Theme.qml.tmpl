    readonly property color cardBot:  "{{base16.base00.default.hex}}"
    readonly property color border:   "{{base16.base02.default.hex}}"
    readonly property color shadow:     Qt.rgba(0, 0, 0, 0.55)
    readonly property color tileBg:   "{{base16.base00.default.hex}}"
    readonly property color subtle:   "{{base16.base04.default.hex}}"
    readonly property color faint:    "{{base16.base03.default.hex}}"
